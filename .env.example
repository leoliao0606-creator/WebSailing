# Local two-client defaults. Node does not load this file unless --env-file is used.
PORT=8787
HOST=0.0.0.0
PUBLIC_DIR=./dist

# The server enforces 4500ms here, reserving 500ms for client migration readiness:
# 2 * HEARTBEAT_MS + HOST_LOSS_MS <= 4500.
HEARTBEAT_MS=1000
HOST_LOSS_MS=2500
RECONNECT_GRACE_MS=30000

# Bounded in-memory signaling capacity and ingress budgets.
MAX_CONNECTIONS=1024
MAX_CONNECTIONS_PER_IP=64
MAX_ROOMS=512
# Only enable when Node is reachable exclusively through a trusted proxy that overwrites X-Forwarded-For.
TRUST_PROXY=false
SIGNAL_RATE_MAX_MESSAGES=120
SIGNAL_RATE_MAX_BYTES=262144
SIGNAL_RATE_WINDOW_MS=1000
# Coarse per-address message and byte ceilings use this multiplier.
SIGNAL_ADDRESS_RATE_MULTIPLIER=8

# Empty ICE configuration is sufficient only for simple local/LAN tests.
ICE_SERVERS_JSON=[]
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8787,http://127.0.0.1:8787

# Production examples (replace hosts and use short-lived TURN credentials):
# ALLOWED_ORIGINS=https://game.example.cn
# ICE_SERVERS_JSON='[{"urls":"stun:stun.game.example.cn:3478"},{"urls":["turn:turn.game.example.cn:3478?transport=udp","turns:turn.game.example.cn:5349?transport=tcp"],"username":"SHORT_LIVED_USERNAME","credential":"SHORT_LIVED_CREDENTIAL","credentialType":"password"}]'
