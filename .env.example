# 逐风 WindChaser 信令服务示例配置。
# `npm run signal` 不会自动加载本文件;试用方式:
#   cp .env.example .env && node --env-file=.env server/index.js
# 各默认值以 server/index.js 的 configFromEnv 为准。

# Node HTTP/WebSocket 监听端口(0–65535)
PORT=8787

# 监听地址;与反向代理同机部署时可改为 127.0.0.1
HOST=0.0.0.0

# 提供的静态文件目录;相对路径按进程工作目录解析
PUBLIC_DIR=dist

# 发送给浏览器的 RTCIceServer[] 单行 JSON。
# 本地默认值不含凭据;生产必须配置从目标网络可达的 STUN/TURN,
# 并用短期凭据机制,绝不要提交真实凭据(见 README「ICE、TURN 与中国区域」)。
ICE_SERVERS_JSON='[{"urls":"stun:stun.example.invalid:3478"}]'

# 逗号分隔的精确 Web Origin 白名单;留空不限制(生产必须显式设置)
ALLOWED_ORIGINS=

# 普通玩家断线后保留座位和恢复令牌的时间(毫秒)
RECONNECT_GRACE_MS=30000

# 房主连接丢失后、正式迁移权威前的恢复窗口(毫秒)
HOST_LOSS_MS=2500

# 服务端 WebSocket ping 周期(毫秒,必须大于 0);
# 启动时强制 2*HEARTBEAT_MS + HOST_LOSS_MS <= 4500(为客户端迁移就绪预留 500ms)
HEARTBEAT_MS=1000

# 内存中信令容量与入口预算上限(均须大于 0)
MAX_CONNECTIONS=1024
MAX_CONNECTIONS_PER_IP=64
MAX_ROOMS=512

# 仅当 Node 只通过会重写 X-Forwarded-For 的可信代理暴露时才启用
TRUST_PROXY=false

# 每连接信令限流:窗口内最多消息数 / 字节数 / 窗口长度(毫秒)
SIGNAL_RATE_MAX_MESSAGES=120
SIGNAL_RATE_MAX_BYTES=262144
SIGNAL_RATE_WINDOW_MS=1000

# 粗粒度的按地址消息/字节上限使用该倍率
SIGNAL_ADDRESS_RATE_MULTIPLIER=8

# 生产示例(替换主机名并使用短期 TURN 凭据):
# ALLOWED_ORIGINS=https://game.example.cn
# ICE_SERVERS_JSON='[{"urls":"stun:stun.game.example.cn:3478"},{"urls":["turn:turn.game.example.cn:3478?transport=udp","turns:turn.game.example.cn:5349?transport=tcp"],"username":"SHORT_LIVED_USERNAME","credential":"SHORT_LIVED_CREDENTIAL","credentialType":"password"}]'
